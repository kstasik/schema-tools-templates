use super::RabbitConnectionManager;
use super::message::PublishMessage;

use arc_swap::ArcSwap;
use lapin::types::ShortString;
use lapin::{BasicProperties, Channel, options::*};
use std::sync::{Arc, OnceLock, RwLock};
use std::time::Duration;
use tokio::sync::Mutex;
use serde_json::Value;
use std::collections::VecDeque;

pub trait Publisher {
    async fn publish<T>(&self, routing_key: &str, message: T) -> Result<(), lapin::Error>
    where
        T: PublishMessage + Send;

    async fn publish_raw(&self, routing_key: &str, payload: &[u8]) -> Result<(), lapin::Error>;
}

pub trait BatchPublisher {
    async fn batch_publish<T>(
        &self,
        routing_key: &str,
        messages: Vec<T>,
    ) -> Result<(), lapin::Error>
    where
        T: PublishMessage + Send;

    async fn batch_publish_raw(
        &self,
        routing_key: &str,
        messages: Vec<&[u8]>,
    ) -> Result<(), lapin::Error>;
}

#[derive(Debug)]
pub struct RabbitProducer {
    manager: Arc<RabbitConnectionManager>,
    channel: ArcSwap<Option<Channel>>,
    reconnect_lock: Mutex<()>,
    exchange: Arc<str>,
}

const PUBLISH_OPTIONS: BasicPublishOptions = BasicPublishOptions {
    mandatory: false,
    immediate: false,
};

const CHANNEL_ACQUIRE_TIMEOUT: Duration = Duration::from_secs(30);

impl RabbitProducer {
    pub async fn new(
        manager: Arc<RabbitConnectionManager>,
        exchange: &str,
    ) -> Result<Self, lapin::Error> {
        let producer = Self {
            manager,
            channel: ArcSwap::new(empty_channel()),
            reconnect_lock: Mutex::new(()),
            exchange: Arc::from(exchange),
        };

        producer.retry_connect(CHANNEL_ACQUIRE_TIMEOUT).await?;
        Ok(producer)
    }

    async fn get_channel(&self) -> Result<Channel, lapin::Error> {
        if let Some(ch) = self.healthy_channel() {
            return Ok(ch);
        }

        tokio::time::timeout(
            CHANNEL_ACQUIRE_TIMEOUT,
            self.retry_connect(CHANNEL_ACQUIRE_TIMEOUT),
        )
        .await
        .unwrap_or_else(|_| {
            Err(lapin::Error::from(std::io::Error::new(
                std::io::ErrorKind::TimedOut,
                "timed out waiting for RabbitMQ channel",
            )))
        })
    }

    async fn retry_connect(&self, deadline: Duration) -> Result<Channel, lapin::Error> {
        const BASE: Duration = Duration::from_millis(500);
        const MAX: Duration = Duration::from_secs(10);
        let mut backoff = BASE;
        let mut attempt = 0u32;

        loop {
            attempt += 1;

            match self.try_establish_channel().await {
                Ok(ch) => {
                    if attempt > 1 {
                        tracing::info!("RabbitMQ channel established after {attempt} attempts");
                    }
                    return Ok(ch);
                }
                Err(e) => {
                    tracing::warn!(
                        attempt,
                        backoff_ms = backoff.as_millis(),
                        timeout_secs = deadline.as_secs(),
                        "RabbitMQ channel unavailable, retrying: {e}"
                    );
                    tokio::time::sleep(backoff).await;
                    backoff = (backoff * 2).min(MAX);
                }
            }
        }
    }

    async fn try_establish_channel(&self) -> Result<Channel, lapin::Error> {
        let _guard = self.reconnect_lock.lock().await;

        if let Some(ch) = self.healthy_channel() {
            return Ok(ch);
        }

        let conn = match self.manager.get().await {
            Ok(c) => c,
            Err(e) => return Err(e),
        };

        let ch = match conn.create_channel().await {
            Ok(ch) => ch,
            Err(e) => {
                if !conn.status().connected() {
                    self.manager.invalidate();
                }
                return Err(e);
            }
        };

        if let Err(e) = ch.confirm_select(ConfirmSelectOptions::default()).await {
            self.manager.invalidate();
            return Err(e);
        }

        self.channel.store(Arc::new(Some(ch.clone())));
        Ok(ch)
    }

    #[inline]
    fn healthy_channel(&self) -> Option<Channel> {
        let guard = self.channel.load();
        let slot: &Option<Channel> = &**guard;
        slot.as_ref().filter(|ch| ch.status().connected()).cloned()
    }

    fn invalidate_channel(&self) {
        self.channel.store(empty_channel());
    }

    pub async fn publish_raw(&self, routing_key: &str, payload: &[u8]) -> Result<(), lapin::Error> {
        let ch = self.get_channel().await?;

        let confirm = ch
            .basic_publish(
                self.exchange.as_ref().into(),
                routing_key.into(),
                PUBLISH_OPTIONS,
                payload,
                BasicProperties::default(),
            )
            .await?
            .await;

        match confirm {
            Ok(_) => Ok(()),
            Err(e) => {
                self.invalidate_channel();
                self.manager.invalidate();
                Err(e.into())
            }
        }
    }

    pub async fn publish<T>(&self, routing_key: &str, message: T) -> Result<(), lapin::Error>
    where
        T: PublishMessage,
    {
        let (headers, payload) = message.into_parts();
        let payload_bytes = serde_json::to_vec(&payload).map_err(|e| {
            lapin::Error::from(std::io::Error::new(std::io::ErrorKind::InvalidData, e))
        })?;
        let props = BasicProperties::default().with_headers(headers);
        let ch = self.get_channel().await?;

        let confirm = ch
            .basic_publish(
                self.exchange.as_ref().into(),
                routing_key.into(),
                PUBLISH_OPTIONS,
                &payload_bytes,
                props,
            )
            .await?
            .await;

        match confirm {
            Ok(_) => Ok(()),
            Err(e) => {
                self.invalidate_channel();
                self.manager.invalidate();
                Err(e.into())
            }
        }
    }

    pub async fn batch_publish_raw(
        &self,
        routing_key: &str,
        messages: Vec<&[u8]>,
    ) -> Result<(), lapin::Error> {
        if messages.is_empty() {
            return Ok(());
        }

        let ch = self.get_channel().await?;

        for payload in messages {
            if let Err(e) = ch
                .basic_publish(
                    self.exchange.as_ref().into(),
                    routing_key.into(),
                    PUBLISH_OPTIONS,
                    payload,
                    BasicProperties::default(),
                )
                .await
            {
                self.invalidate_channel();
                self.manager.invalidate();
                return Err(e);
            }
        }

        if let Err(e) = ch.wait_for_confirms().await {
            self.invalidate_channel();
            self.manager.invalidate();
            return Err(e);
        }

        Ok(())
    }

    pub async fn batch_publish<T>(
        &self,
        routing_key: &str,
        messages: Vec<T>,
    ) -> Result<(), lapin::Error>
    where
        T: PublishMessage,
    {
        if messages.is_empty() {
            return Ok(());
        }

        let prepared: Vec<(Vec<u8>, BasicProperties)> = messages
            .into_iter()
            .map(|msg| -> Result<_, lapin::Error> {
                let (headers, payload) = msg.into_parts();
                Ok((
                    serde_json::to_vec(&payload).map_err(|e| {
                        lapin::Error::from(std::io::Error::new(std::io::ErrorKind::InvalidData, e))
                    })?,
                    BasicProperties::default().with_headers(headers),
                ))
            })
            .collect::<Result<_, _>>()?;

        let ch = self.get_channel().await?;

        for (payload, props) in prepared {
            if let Err(e) = ch
                .basic_publish(
                    self.exchange.as_ref().into(),
                    routing_key.into(),
                    PUBLISH_OPTIONS,
                    &payload,
                    props,
                )
                .await
            {
                self.invalidate_channel();
                self.manager.invalidate();
                return Err(e);
            }
        }

        if let Err(e) = ch.wait_for_confirms().await {
            self.invalidate_channel();
            self.manager.invalidate();
            return Err(e);
        }

        Ok(())
    }
}

impl Publisher for RabbitProducer {
    async fn publish<T>(&self, routing_key: &str, message: T) -> Result<(), lapin::Error>
    where
        T: PublishMessage + Send,
    {
        self.publish(routing_key, message).await
    }

    async fn publish_raw(&self, routing_key: &str, payload: &[u8]) -> Result<(), lapin::Error> {
        self.publish_raw(routing_key, payload).await
    }
}

impl<T: Publisher> Publisher for Arc<T> {
    async fn publish<M>(&self, routing_key: &str, message: M) -> Result<(), lapin::Error>
    where
        M: PublishMessage + Send,
    {
        (**self).publish(routing_key, message).await
    }

    async fn publish_raw(&self, routing_key: &str, payload: &[u8]) -> Result<(), lapin::Error> {
        (**self).publish_raw(routing_key, payload).await
    }
}

impl BatchPublisher for RabbitProducer {
    async fn batch_publish<T>(
        &self,
        routing_key: &str,
        messages: Vec<T>,
    ) -> Result<(), lapin::Error>
    where
        T: PublishMessage + Send,
    {
        self.batch_publish(routing_key, messages).await
    }

    async fn batch_publish_raw(
        &self,
        routing_key: &str,
        messages: Vec<&[u8]>,
    ) -> Result<(), lapin::Error> {
        self.batch_publish_raw(routing_key, messages).await
    }
}

fn empty_channel() -> Arc<Option<Channel>> {
    static EMPTY: OnceLock<Arc<Option<Channel>>> = OnceLock::new();
    EMPTY.get_or_init(|| Arc::new(None)).clone()
}

#[derive(Debug, Clone)]
pub struct SentMessage {
    pub routing_key: String,
    pub payload: Value,
}

#[derive(Clone)]
pub struct MockProducer {
    sent_messages: Arc<RwLock<VecDeque<SentMessage>>>,
}

impl Default for MockProducer {
    fn default() -> Self {
        Self::new()
    }
}

impl MockProducer {
    pub fn new() -> Self {
        Self {
            sent_messages: Arc::new(RwLock::new(VecDeque::with_capacity(16))),
        }
    }

    pub fn get_sent_messages(&self) -> Vec<SentMessage> {
        self.sent_messages.read().unwrap().iter().cloned().collect()
    }

    pub fn find_sent_messages(&self, routing_key: &str) -> Option<SentMessage> {
        self.sent_messages
            .read()
            .unwrap()
            .iter()
            .find(|m| m.routing_key == routing_key)
            .cloned()
    }

    pub fn clear_messages(&self) {
        self.sent_messages.write().unwrap().clear();
    }

    pub fn get_message_count(&self) -> usize {
        self.sent_messages.read().unwrap().len()
    }

    pub fn get_last_message(&self) -> Option<SentMessage> {
        self.sent_messages.read().unwrap().back().cloned()
    }
}

impl Publisher for MockProducer {
    async fn publish<T>(&self, routing_key: &str, message: T) -> Result<(), lapin::Error>
    where
        T: PublishMessage + Send,
    {
        let (_meta, payload) = message.into_parts();

        let sent_message = SentMessage {
            routing_key: routing_key.to_string(),
            payload: serde_json::to_value(payload).unwrap_or(Value::Null),
        };

        self.sent_messages.write().unwrap().push_back(sent_message);
        Ok(())
    }

    async fn publish_raw(&self, routing_key: &str, payload: &[u8]) -> Result<(), lapin::Error> {
        let sent_message = SentMessage {
            routing_key: routing_key.to_string(),
            payload: serde_json::from_slice(payload).unwrap_or(Value::Null),
        };

        self.sent_messages.write().unwrap().push_back(sent_message);
        Ok(())
    }
}
