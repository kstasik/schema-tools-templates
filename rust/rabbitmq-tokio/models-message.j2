{# type=models,filename=rabbitmq/message.rs,min_version=0.2.0 #}
{% extends "models.j2" %}
{% block use %}
use lapin::types::{AMQPValue, LongString, ShortString};
use lapin::types::FieldTable;
use serde::de::DeserializeOwned;

pub trait PublishMessage {
    type Payload: Serialize;
    fn into_parts(self) -> (FieldTable, Self::Payload);
}

pub trait Message: Sized {
    fn message_type() -> &'static str;
}

pub trait MessageExtractor: Sized {
    fn message_type() -> &'static str;

    fn extract_payload(payload: &[u8]) -> Option<Self>;

    fn extract_from_message(msg: &super::consumer::IncomingMessage<'_>) -> Option<Self> {
        Self::extract_payload(msg.data)
    }
}

impl<T> MessageExtractor for T
where
    T: Message + DeserializeOwned,
{
    fn message_type() -> &'static str {
        T::message_type()
    }

    fn extract_payload(payload: &[u8]) -> Option<Self> {
        match serde_json::from_slice(payload) {
            Ok(value) => Some(value),
            Err(e) => {
                tracing::error!(
                    message_type = %T::message_type(),
                    error = %e,
                    "Failed to deserialize message"
                );
                None
            }
        }
    }
}

{% endblock use %}

{% block end %}

fn generate_time_string() -> String {
    let now = std::time::SystemTime::now();
    let now: DateTime<Utc> = now.into();

    now.to_rfc3339()
}
{% endblock end %}
